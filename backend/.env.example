WHISPER_MODEL=base
# Whisper skips audio when no_speech_prob exceeds this → HIGHER = keep more speech (try 0.75–0.95).
# Set to none to only use built-in tiers. Optional ISO code fixes mis-detection e.g. en, hi.
WHISPER_NO_SPEECH_THRESHOLD=
WHISPER_LANGUAGE=
# FFmpeg audio filter applied before Whisper; empty/-/none disables. Helps quiet microphones.
WHISPER_FFMPEG_AFILTER=dynaudnorm=f=150:g=15,volume=3dB
# Comma-separated list; defaults include localhost/127.0.0.1 for Vite when it uses 5173–5175.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
